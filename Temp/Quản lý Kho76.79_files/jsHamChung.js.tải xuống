        dataType: "json",
        url: "/Public/ddlQuan",
        data: { iID_MaTinh: iID_MaTinh, Dollar: dollar },
        success: function (item) {
            x = (ParentID != "" ? ParentID + "_" : "");
            $("#" + (ParentID != "" ? ParentID + "_" : "") + "iID_MaQuan").html(item);
        }
    });
    $.ajax({
        type: "POST",
        dataType: "json",
        url: "/Public/DDLPhuongXa",
        data: { iID_MaTinh: iID_MaTinh },
        success: function (item) {
            $("#" + (ParentID != "" ? ParentID + "_" : "") + "iID_MaPhuongXa").html(item);
        }
    });
}

