
function SetValueNumber(id,value)
{
    $('#' + id).val(value);
    $('#' + id + '_show').val(FormatNumber(value));
}
function SetValueText(id, value)
{
    $('#' + id).val(value);
}

function jsCreateElementCheckBox(tag,type,id,checked,value)
{
    var tag = document.createElement(tag);
    tag.setAttribute('type', type);
    tag.setAttribute("id", id);
    tag.setAttribute("name", id);
    tag.value = value;
    if (checked.length > 0)
    {
        tag.setAttribute('checked', 'checked');
    }
    return tag;
}

function jsCreateElement(tag,type,id,value)
{
    var tag = document.createElement(tag);
    tag.setAttribute('type', type);
    tag.setAttribute("id", id);
    tag.setAttribute("name", id);
    tag.value = value;
    return tag;
}

function checkboxAllBootstrap()
{
    $("#checkAll").click(function () {
        var check = $(this).prop('checked');
        if (check == true) {
            $('.checker').find('span').addClass('checked');
            $('.checkbox').prop('checked', true);
        } else {
            $('.checker').find('span').removeClass('checked');
            $('.checkbox').prop('checked', false);
        }
    });
}

