$(document).on('click', '.removeTD', function () {
    const iID_File = $(this).data('file').toString();
    const LoaiFile = $(this).data('loaifile');
    const deleteInput = $('#fileThuaDatDelete');
    const deletedList = deleteInput.val()?.split(';').filter(Boolean) || [];
    if (!deletedList.includes(iID_File)) {
        deletedList.push(iID_File);
    }
    $('#fileThuaDatDelete').val(deletedList.join(';'));
    $("#" + iID_File + "_" + LoaiFile).remove();

});
