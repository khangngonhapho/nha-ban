$(document).on('click', '.del', function () {
    
    var id = $(this).data('id');
    var hidden = $(this).data('hidden');
    var url = "/Hang/Delete";
    var reason = $('#deleteReason').val()
    if (hidden=="1" && reason.trim().length == 0) {
        toastr.success("Đề nghị nhập lý do phù hợp");
    } else {
        $.ajax({
            url: url,
            type: 'POST',
            data: { id: id, hidden: hidden, reason: reason },
            success: function (data) {
                if (!data.success) {
                    toastr.error(data.error);
                }  else {
                    $("#tr_" + id).remove();
                    toastr.success(data.error);
                }
            }
        });
        $("#modal-DeleteReason").modal("hide")
    }
    

});
