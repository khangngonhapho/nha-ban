$(document).on('submit', '#submit_form', function (e) {
    const keptIds = ($('#fileThuaDats').val() || '').split(';').filter(Boolean);
    const deletedIds = ($('#fileThuaDatDelete').val() || '').split(';').filter(Boolean);
    const remainingOld = keptIds.filter(id => !deletedIds.includes(id));

    const hasNewFiles = $('#fileThuaDat')[0].files.length > 0;

    if (remainingOld.length == 0 && !hasNewFiles) {
        e.preventDefault();
        toastr.error("Bạn phải thêm ít nhất một ảnh thửa đất.");
    }
});

