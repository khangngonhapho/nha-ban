function turn(project) {
    if (project && project > 0) {
        $("#Create_HangInfo").hide();
        $("#Create_HangAddress").hide();
        $("#Create_Bank").hide();
        $("#Create_TrangThaiSoDo").show();
        $("#Create_HopDongDauChu").html("Hợp đồng");
        $('#Create_sDienThoaiNguonHang').prop('readonly', true);
        $("#Create_DienThoaiNguonHang").html("Hotline");
    } else {
        $("#Create_HangInfo").show();
        $("#Create_HangAddress").show();
        $("#Create_Bank").show();
        $("#Create_TrangThaiSoDo").hide();
        $("#Create_titleHuong").html("Hướng nhà");
        $("#Create_titleTang").html("Số tầng");
        $("#Create_titleAddress").html("Ngõ, số nhà");
        $("#Create_titleZone").html("Đường phố");

        $("#Create_HopDongDauChu").html("Người cấp nguồn");
        $('#Create_sDienThoaiNguonHang').prop("readonly", false);
        $("#Create_DienThoaiNguonHang").html("Điện thoại nguồn hàng");
    }
}
