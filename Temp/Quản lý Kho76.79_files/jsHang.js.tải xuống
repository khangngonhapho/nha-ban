});
    //Map//
    let map;
    var marker;
    var markers = [];
    var myLatLng = { lat: 21.0135057, lng: 105.8561912 };
    function initMap() {

        map = new google.maps.Map(document.getElementById("map"), {
            center: { lat: 21.0135057, lng: 105.8561912 },
            zoom: 15,

        });

        marker = new google.maps.Marker({
            position: myLatLng,
            map,
            title: "Hello World!",
        });
        markers.push(marker);
        google.maps.event.addListener(map, 'click', function (event) {

            placeMarker(event.latLng);
        });

        function placeMarker(location) {

            clearMarkers();

            // if (marker == undefined) {
            marker = new google.maps.Marker({
                position: location,
                map: map,
                animation: google.maps.Animation.DROP,
            });
            //}
            //else {
            //    marker.setPosition(location);
            //}
            map.setCenter(location);
            markers.push(marker);
            var json = JSON.stringify(location.toJSON(), null, 2);
            var obj = JSON.parse(json);
            SelectLatLng(obj);
            // alert(obj.lat);
            //alert(json);

        }


        function clearMarkers() {
            for (var i = 0; i < markers.length; i++) {
                markers[i].setMap(null);
            }
        }
    }
    function SelectLatLng(obj) {

        $("#Lat").val(obj.lat);
        $("#Lng").val(obj.lng);
        $("#Create_iLat").val(obj.lat);
        $("#Create_iLng").val(obj.lng);
        $("#Create_iLat_show").val(obj.lat);
        $("#Create_iLng_show").val(obj.lng);
    }
    function SetCenter(location) {
        marker = new google.maps.Marker({
            position: location,
            map: map,
            animation: google.maps.Animation.DROP,
        });
        //}
        //else {
        //    marker.setPosition(location);
        //}
        map.setCenter(location);
        markers.push(marker);
        SelectLatLng(location);
    }
