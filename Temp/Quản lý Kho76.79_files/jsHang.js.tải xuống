function duanOnchange() {
    var v = $("#Create_iDuAn").val();
    turn(v);
    if (v > 0) {
        $.ajax({
            type: "POST",
            dataType: "json",
            url: "/Public/get_Auto_DuAn",
            data: { iDuAn: v },
            success: function (item) {
                console.log(item.iID_MaTinh, item.iID_MaQuan, item.iID_MaPhuongXa)
                $("#Create_iID_MaTinh").val(item.iID_MaTinh);
                $("#Create_iID_MaQuan").val(item.iID_MaQuan);
                $("#Create_iID_MaPhuongXa").val(item.iID_MaPhuongXa);
                $("#Create_sDuongPho").val(item.sDiaChi);
                $("#Create_sDienThoaiNguonHang").val(item.sHotline);
                if (item.iPhanLoai == 1) {
                    $("#Create_titleAddress").html("Địa chỉ");
                    $("#Create_titleZone").html("Phân khu");
                    $("#Create_titleHuong").html("Hướng nhà");
                    $("#Create_titleTang").html("Số tầng");
                } else {
                    $("#Create_titleAddress").html("Căn");
                    $("#Create_titleZone").html("Tòa");
                    $("#Create_titleHuong").html("Hướng ban công");
                    $("#Create_titleTang").html("Tầng");
                }
            }
        });
    }
}
