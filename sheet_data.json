ng Cầu Kiệu. Đặc điểm hẻm rộng 30m, mặt tiền đường lớn, thuận lợi cho việc di chuyển và kinh doanh. Nhà nằm trong khu vực sầm uất, dễ dàng tiếp cận các tiện ích xung quanh. \n\n+ Kết cấu: Căn nhà được xây dựng 3 tầng với 4 phòng ngủ và 3 nhà vệ sinh, phù hợp cho gia đình đông người hoặc cho thuê. Thiết kế thông minh, không gian sống thoải mái với đầy đủ tiện nghi. \n\n+ Kết nối & Tiện ích: Đường Hoàng Văn Thụ nổi tiếng với sự nhộn nhịp và an ninh tốt. Khu vực dân trí cao, gần các trục đường lớn như Đinh Tiên Hoàng, Nguyễn Đình Chiểu, thuận tiện cho việc di chuyển đến các quận lân cận. \n\n+ Pháp lý: Sổ hồng riêng, pháp lý rõ ràng, sẵn sàng giao dịch."},{"v":"https://tk-assets.spms2.com/2026/03/27/2anh-8BCB587C-mn939wpb_391_8.jpg"},{"v":"https://tk-assets.spms2.com/2026/03/27/2anh-8BCB587C-mn939wpb_303_6.jpg"},{"v":"https://tk-assets.spms2.com/2026/03/27/2anh-8BCB587C-mn939wpb_434_9.jpg"},{"v":"https://tk-assets.spms2.com/2026/03/27/2anh-8BCB587C-mn939wpb_816_17.jpg"},null,null,null,null,null,null,{"v":"Date(2026,4,21)","f":"5/21/2026"},{"v":"Phường 7"},{"v":4.0,"f":"4"},{"v":3.0,"f":"3"},{"v":"HOÀNG VĂN THỤ"},null,null,{"v":"SYS-MP76VU0C-CV"},null,null,{"v":null}]},{"c":[{"v":"HWTITHT"},{"v":"Mặt tiền Trần Hữu Trang 60.1/45m2 4Tầng 4x15 15.5 tỷ Phú Nhuận Phú Nhuận"},{"v":60.1,"f":"60.1"},{"v":4.0,"f":"4"},{"v":4.0,"f":"4"},{"v":15.5,"f":"15.5"},null,{"v":"Phú Nhuận"},{"v":"Mặt tiền"},{"v":"Tây Nam"},{"v":"Mặt tiền đường"},{"v":4.0,"f":"4"},{"v":"Bình thường"},null,null,null,null,{"v":"https://tk-assets.spms2.com/2026/03/08/2anm-35B9E356-mmhp5sa2_422_11.jpg"},{"v":"https://tk-assets.spms2.com/2026/03/08/2anm-35B9E356-mmhp5sa2_510_13.jpg"},{"v":"https://tk-assets.spms2.com/2026/03/08/2anm-35B9E356-mmhp5sa2_582_15.jpg"},{"v":"https://tk-assets.spms2.com/2026/03/08/2anm-35B9E356-mmhp5sa2_657_17.jpg"},null,null,null,null,null,null,null,{"v":"11"},null,null,{"v":"Trần Hữu Trang"},null,null,{"v":"SYS-MP76PHIE-D0"},null,null,{"v":null}]},{"c":[{"v":"BWHIBNICV"},{"v":"Vườn C