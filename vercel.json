{
  "version": 2,
  "builds": [
    {
      "src": "api/index.js",
      "use": "@vercel/node",
      "config": {
        "includeFiles": ["index.html"]
      }
    }
  ],
  "routes": [
    { "src": "/avatarKhangNgo.jpg", "dest": "/avatarKhangNgo.jpg" },
    { "src": "/(.*)", "dest": "api/index.js" }
  ]
}
